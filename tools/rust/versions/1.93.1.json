      },
      "source_url_template": "https://static.rust-lang.org/rustup/dist/{rustup_target}/rustup-init",
      "invoke": {
        "args": ["-y", "--default-toolchain", "1.93.1", "--profile", "default"],
        "env": {
          "CARGO_HOME": "/cache/cargo",
          "RUSTUP_HOME": "/cache/rustup"
        }
      },
